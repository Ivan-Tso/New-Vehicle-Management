# AI Maintenance Analysis - Environment Variables
# Copy this file to .env and fill in your API keys

# Zhipu AI (GLM-4.5) API Key
# Get your key from: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# Alternative: Generic LLM API key
LLM_API_KEY=your_generic_llm_key_here

# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and add your API keys
# 3. Make sure .env is NOT committed to git (it's in .gitignore)
